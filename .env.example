# ===========================================
# Idol Meta Tournament - Environment Variables
# ===========================================
# Copy this file to .env for development
# Copy to .env.production for production deployment

# ===========================================
# DATABASE (REQUIRED)
# ===========================================

# Development - SQLite
DATABASE_URL="file:./db/custom.db"

# Production - PostgreSQL (choose one below)
# Vercel Postgres: postgres://user:password@host/db?sslmode=require
# Supabase: postgresql://postgres:password@db.project.supabase.co:5432/postgres
# Neon: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Railway: postgresql://postgres:password@host.railway.app:5432/railway

# ===========================================
# NEXTAUTH (REQUIRED)
# ===========================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-min-32-characters-long"

# Your app URL
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# APP CONFIGURATION
# ===========================================

NEXT_PUBLIC_APP_NAME="Idol Meta Tournament"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# SUPER ADMIN (for seeding)
# ===========================================

SUPER_ADMIN_PHONE="+6281349924210"
SUPER_ADMIN_PASSWORD="tazevsta"

# ===========================================
# PAYMENT GATEWAY - MIDTRANS (OPTIONAL)
# ===========================================

MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""

# ===========================================
# PAYMENT GATEWAY - XENDIT (OPTIONAL)
# ===========================================

XENDIT_SECRET_KEY=""
XENDIT_PUBLIC_KEY=""

# ===========================================
# WHATSAPP BOT (OPTIONAL)
# ===========================================

WHATSAPP_SESSION_ID="idol-meta-bot"

# ===========================================
# NODE ENVIRONMENT
# ===========================================

NODE_ENV="development"
