# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.production and fill in your values

# Database - PostgreSQL (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/idol_meta?sslmode=require"

# For Vercel Postgres:
# DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# For Supabase:
# DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres"

# For Neon:
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth.js (REQUIRED)
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production-min-32-chars"
NEXTAUTH_URL="https://your-domain.com"

# Payment Gateway - Midtrans (OPTIONAL)
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxx"

# Payment Gateway - Xendit (OPTIONAL)
XENDIT_SECRET_KEY="xnd_development_xxxxx"
XENDIT_PUBLIC_KEY="xnd_public_development_xxxxx"

# WhatsApp Bot (OPTIONAL)
WHATSAPP_SESSION_ID="idol-meta-bot-prod"

# App Configuration
NEXT_PUBLIC_APP_NAME="Idol Meta Tournament"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Super Admin Credentials (for seeding)
SUPER_ADMIN_PHONE="+6281349924210"
SUPER_ADMIN_PASSWORD="tazevsta"

# Node Environment
NODE_ENV="production"
